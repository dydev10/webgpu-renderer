{
  "name": "@dydev10/webgpu-renderer",
  "version": "0.3.2",
  "description": "WebGPU renderer for the browser with a scene API and two-pass composite pipeline.",
  "keywords": [
    "webgpu",
    "renderer",
    "3d",
    "graphics",
    "browser"
  ],
  "author": "DY Dev <dydev420@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dydev10/webgpu-renderer"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:lib": "tsup",
    "lint": "eslint",
    "lint:ts": "eslint"
  },
  "peerDependencies": {
    "gl-matrix": "^3.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.2.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^9.2.0",
    "globals": "^15.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.2.2",
    "typescript-eslint": "^7.8.0",
    "vite": "^5.2.0",
    "vite-plugin-glsl": "^1.3.0"
  },
  "dependencies": {
    "@types/node": "^20.12.8",
    "@webgpu/types": "^0.1.40",
    "gl-matrix": "^3.4.3"
  }
}
